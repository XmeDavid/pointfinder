POSTGRES_DB=pointfinder
POSTGRES_USER=scout
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-to-a-strong-256-bit-secret

FRONTEND_URL=https://pointfinder.pt
CORS_ORIGINS=http://localhost,https://pointfinder.pt,https://pointfinder.ch

PGDATA_PATH=./data/pgdata
UPLOADS_PATH=./data/uploads
SECRETS_PATH=./secrets
CERTBOT_CONF_PATH=./certbot/conf
CERTBOT_WWW_PATH=./certbot/www
HTTP_PORT=80
HTTPS_PORT=443
PROMETHEUS_PORT=9090

SPRING_PROFILES_ACTIVE=prod
JAVA_TOOL_OPTIONS=-Xms256m -Xmx1200m

MAIL_ENABLED=false
MAIL_PASSWORD=
MAIL_FROM=info@pointfinder.pt

APNS_ENABLED=false
APNS_KEY_PATH=file:/app/config/apns-key.p8
APPLE_PROD_APNS_KEY=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.prayer.pointfinder
APNS_PRODUCTION=false

FCM_ENABLED=false
FCM_CREDENTIALS_PATH=file:/app/config/firebase-service-account.json
FCM_PROJECT_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ORG_BASE_MONTHLY=
STRIPE_PRICE_ORG_BASE_ANNUAL=
STRIPE_PRICE_ORG_HIGH_MONTHLY=
STRIPE_PRICE_ORG_HIGH_ANNUAL=

QUOTA_ENFORCEMENT_ENABLED=false
STORAGE_TYPE=local
S3_ENDPOINT=
S3_REGION=eu-central-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
